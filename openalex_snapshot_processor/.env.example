# ── Snapshot processor ────────────────────────────────────────────────────────
# Absolute path to the snapshot root on the host machine.
# Inside the container this is always mounted at /data
SNAPSHOT_ROOT=/data
BLOB_BATCH_SIZE=10000

# ── Azure Blob Storage ────────────────────────────────────────────────────────
STORAGE_BLOB_ACCOUNT=
STORAGE_BLOB_CONTAINER=
STORAGE_BLOB_ACCOUNT_KEY=

# ── DESTINY Repository ────────────────────────────────────────────────────────
REPOSITORY_ENDPOINT=https://your-destiny-api/
TOKEN_ENDPOINT=https://login.microsoftonline.com/<tenant-id>/oauth2/v2.0/token
APP_REGISTRATION_APP_ID=
APP_REGISTRATION_SECRET=
TENANT_ID=

# ── Airflow ───────────────────────────────────────────────────────────────────
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow
AIRFLOW_UID=50000
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
